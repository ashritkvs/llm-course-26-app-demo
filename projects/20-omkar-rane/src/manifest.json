{
  "manifest_version": 3,
  "name": "PR Description Writer",
  "version": "1.0.0",
  "description": "Generate PR descriptions from git diffs using OpenAI GPT",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://github.com/*",
    "https://api.github.com/*",
    "https://api.openai.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*/compare/*",
        "https://github.com/*/pull/new/*",
        "https://github.com/*/compare"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "styles/content.css"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://api.openai.com;"
  }
}
