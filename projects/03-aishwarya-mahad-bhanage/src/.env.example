# ─── DataLineage AI — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git (it's in .gitignore).

# ── REQUIRED ────────────────────────────────────────────────────────────────

# Anthropic API key — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Comma-separated API keys for clients of YOUR API.
# Generate one with: openssl rand -hex 16
# Format: prefix any string with "dl_" so they're easy to spot in logs.
API_KEYS=dl_dev_local_only_change_me

# ── OPTIONAL — dbt project ──────────────────────────────────────────────────

DBT_PROJECT_PATH=./dbt_demo
MANIFEST_PATH=./dbt_demo/target/manifest.json

# ── OPTIONAL — dbt Cloud integration ────────────────────────────────────────

DBT_CLOUD_API_TOKEN=
DBT_CLOUD_ACCOUNT_ID=
DBT_CLOUD_BASE_URL=https://cloud.getdbt.com

# ── OPTIONAL — security ─────────────────────────────────────────────────────

# Set to false ONLY for local dev — disables API key auth
REQUIRE_API_KEY=true

# CORS — comma-separated list of allowed origins
# Dev:  *
# Prod: https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# Rate limits per API key
RATE_LIMIT_FAST=10/minute
RATE_LIMIT_AGENTIC=3/minute

# ── OPTIONAL — runtime ──────────────────────────────────────────────────────

# Max time (seconds) to wait for Claude responses before giving up
LLM_TIMEOUT_SECONDS=30

# Max tool-call iterations the agent can do per debug session
AGENT_MAX_ITERATIONS=15

# Max request body size in MB
MAX_REQUEST_SIZE_MB=5

# ── OPTIONAL — environment ──────────────────────────────────────────────────

# Affects log format and /docs visibility
# Options: development | staging | production
ENVIRONMENT=development

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
